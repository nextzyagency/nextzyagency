---
// Cta.astro
import Star from "../ui/Star.astro";
---

<section
  id="contacto"
  class="relative w-full py-32 flex flex-col items-center px-6 overflow-hidden"
>
  <Star class="top-20 left-20 w-8 h-8 opacity-40" />
  <Star class="bottom-40 right-[15%] w-12 h-12 opacity-20 text-nextzy-purple" />

  <div
    class="cta-container w-full max-w-4xl mx-auto glass-floating rounded-[2.5rem] p-10 md:p-16 flex flex-col items-center text-center relative z-10 border border-nextzy-gray-700/50 shadow-2xl"
  >
    <div
      class="absolute inset-0 bg-gradient-to-b from-nextzy-purple/5 to-transparent rounded-[2.5rem] pointer-events-none"
    >
    </div>

    <h2
      class="text-3xl md:text-4xl lg:text-6xl font-black text-white mb-6 tracking-tight z-10 w-full text-center leading-[1.1]"
    >
      Consigue tu página web <br />
      <span class="font-drama italic text-nextzy-purple-light normal-case pr-4"
        >profesional</span
      >
    </h2>
    <p
      class="text-lg md:text-xl text-nextzy-gray-400 font-medium max-w-2xl mb-12 z-10"
    >
      Envía una solicitud y comencemos a darle la confianza que tus clientes se
      merecen. Nuestro equipo se encargará de todo.
    </p>

    <div class="mt-8 z-10 w-full max-w-sm">
      <a
        href="https://wa.me/573052487564?text=Hola,%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20el%20dise%C3%B1o%20de%20una%20p%C3%A1gina%20web"
        target="_blank"
        rel="noopener noreferrer"
        onclick="fbq('track', 'Contact');"
        class="cta-button relative w-full flex items-center justify-center bg-nextzy-white text-nextzy-black font-bold text-lg py-4 px-8 rounded-xl overflow-hidden group shadow-[0_0_20px_rgba(255,255,255,0.1)] outline-none"
      >
        <span class="relative z-10 flex items-center justify-center gap-2 group-hover:text-white transition-colors duration-300">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Contactar por WhatsApp
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-[#25D366] to-[#128C7E] transform scale-x-0 origin-left transition-transform duration-300 ease-out group-hover:scale-x-100 z-0"></div>
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector(".cta-container");
  if (container) {
    gsap.fromTo(
      container,
      { scale: 0.95, opacity: 0, y: 50 },
      {
        scale: 1,
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: container,
          start: "top 85%",
        },
      },
    );
  }

  // Botón Magnético
  const btn = document.querySelector(".cta-button") as HTMLElement;
  if (btn) {
    btn.addEventListener("mousemove", (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;

      gsap.to(btn, {
        x: x * 0.15,
        y: y * 0.15,
        duration: 0.3,
        ease: "power2.out",
      });
    });

    btn.addEventListener("mouseleave", () => {
      gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: "elastic.out(1, 0.3)" });
    });
  }
</script>
