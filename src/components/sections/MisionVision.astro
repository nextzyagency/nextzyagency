---
// MisionVision.astro
---

<section id="mision-vision" class="w-full relative py-20 px-6 overflow-hidden">

  <!-- Ambient glow background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute left-1/4 top-1/2 -translate-y-1/2 w-96 h-96 bg-[#8A4FFF]/8 rounded-full blur-[120px]"></div>
    <div class="absolute right-1/4 top-1/2 -translate-y-1/2 w-96 h-96 bg-[#8A4FFF]/5 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">

    <!-- Encabezado -->
    <div class="flex flex-col items-center text-center max-w-2xl mx-auto mb-14 mv-header">
      <div class="flex items-center gap-4 mb-4">
        <span class="w-8 h-[2px] bg-[#8A4FFF]/50"></span>
        <span class="text-[#8A4FFF] font-semibold tracking-widest text-sm uppercase">Quiénes somos</span>
        <span class="w-8 h-[2px] bg-[#8A4FFF]/50"></span>
      </div>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold leading-tight tracking-tight text-white">
        El propósito que nos mueve cada día
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">

      <!-- Card Misión -->
      <div class="mv-card group relative rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-10 flex flex-col gap-6 overflow-hidden transition-all duration-500 hover:border-[#8A4FFF]/40 hover:bg-white/[0.06]">

        <!-- Top accent line -->
        <div class="absolute top-0 left-8 right-8 h-[2px] bg-gradient-to-r from-transparent via-[#8A4FFF]/60 to-transparent"></div>

        <!-- Hover glow -->
        <div class="absolute -inset-1 rounded-2xl bg-[#8A4FFF]/0 group-hover:bg-[#8A4FFF]/5 transition-all duration-500 pointer-events-none"></div>

        <!-- Icon -->
        <div class="w-14 h-14 rounded-xl border border-[#8A4FFF]/30 bg-[#8A4FFF]/10 flex items-center justify-center shrink-0 transition-all duration-300 group-hover:border-[#8A4FFF]/60 group-hover:bg-[#8A4FFF]/20">
          <!-- Target / Compass icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#8A4FFF]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7z" />
          </svg>
        </div>

        <!-- Text -->
        <div>
          <h3 class="text-2xl font-bold text-white mb-4">Nuestra Misión</h3>
          <p class="text-gray-400 font-medium leading-relaxed text-base">
            Diseñar y desarrollar experiencias digitales que conviertan visitantes en clientes reales. Construimos cada proyecto con precisión estratégica, código limpio y un enfoque obsesivo en los resultados de nuestros clientes.
          </p>
        </div>

        <!-- Bottom label -->
        <div class="mt-auto flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#8A4FFF]"></span>
          <span class="text-[#8A4FFF] text-sm font-semibold tracking-wider uppercase">Misión</span>
        </div>
      </div>

      <!-- Card Visión -->
      <div class="mv-card group relative rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-10 flex flex-col gap-6 overflow-hidden transition-all duration-500 hover:border-[#8A4FFF]/40 hover:bg-white/[0.06]">

        <!-- Top accent line -->
        <div class="absolute top-0 left-8 right-8 h-[2px] bg-gradient-to-r from-transparent via-[#8A4FFF]/60 to-transparent"></div>

        <!-- Hover glow -->
        <div class="absolute -inset-1 rounded-2xl bg-[#8A4FFF]/0 group-hover:bg-[#8A4FFF]/5 transition-all duration-500 pointer-events-none"></div>

        <!-- Icon -->
        <div class="w-14 h-14 rounded-xl border border-[#8A4FFF]/30 bg-[#8A4FFF]/10 flex items-center justify-center shrink-0 transition-all duration-300 group-hover:border-[#8A4FFF]/60 group-hover:bg-[#8A4FFF]/20">
          <!-- Eye / Vision icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#8A4FFF]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        </div>

        <!-- Text -->
        <div>
          <h3 class="text-2xl font-bold text-white mb-4">Nuestra Visión</h3>
          <p class="text-gray-400 font-medium leading-relaxed text-base">
            Ser la agencia de referencia en Latinoamérica para negocios que quieren crecer en digital. Aspiramos a un futuro donde cada empresa, sin importar su tamaño, tenga acceso a una presencia web que compita al más alto nivel.
          </p>
        </div>

        <!-- Bottom label -->
        <div class="mt-auto flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#8A4FFF]"></span>
          <span class="text-[#8A4FFF] text-sm font-semibold tracking-wider uppercase">Visión</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animación del encabezado
  gsap.fromTo('.mv-header',
    { y: 40, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '.mv-header',
        start: 'top 85%',
      }
    }
  );

  // Animación de las cards con stagger
  const cards = gsap.utils.toArray('.mv-card');
  cards.forEach((card: any, i) => {
    gsap.fromTo(card,
      { y: 60, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.9,
        delay: i * 0.18,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
        }
      }
    );
  });
</script>
