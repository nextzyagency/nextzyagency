---
// SocialProof.astro
import Star from '../ui/Star.astro';
---
<section class="w-full relative z-30 py-8 px-6 -mt-8 mx-auto -mb-8">
  <div class="max-w-7xl mx-auto backdrop-blur-md bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.12)] social-proof-container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 justify-center divide-x-0 md:divide-x divide-white/10">
      
      <!-- Stat 1 -->
      <div class="flex flex-col items-center text-center px-4 social-proof-item">
        <h3 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-1"><span class="text-[#8A4FFF]">+</span>50</h3>
        <p class="text-sm md:text-base text-gray-400 font-medium">Proyectos Entregados</p>
      </div>

      <!-- Stat 2 -->
      <div class="flex flex-col items-center text-center px-4 social-proof-item">
        <h3 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-1">100<span class="text-[#8A4FFF]">%</span></h3>
        <p class="text-sm md:text-base text-gray-400 font-medium">Optimizados para SEO</p>
      </div>

      <!-- Stat 3 -->
      <div class="flex flex-col items-center text-center px-4 social-proof-item">
        <h3 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-1"><span class="text-[#8A4FFF]">+</span>150<span class="text-white">%</span></h3>
        <p class="text-sm md:text-base text-gray-400 font-medium">Aumento en Conversión</p>
      </div>

      <!-- Stat 4 -->
      <div class="flex flex-col items-center text-center px-4 social-proof-item">
        <h3 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-1">24<span class="text-[#8A4FFF]">/</span>7</h3>
        <p class="text-sm md:text-base text-gray-400 font-medium">Soporte Premium</p>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector('.social-proof-container');
  if (container) {
    gsap.fromTo('.social-proof-container',
      { y: 30, opacity: 0 },
      { 
        y: 0, 
        opacity: 1, 
        duration: 1, 
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.social-proof-container',
          start: 'top 95%',
        }
      }
    );

    gsap.fromTo('.social-proof-item',
      { y: 20, opacity: 0 },
      { 
        y: 0, 
        opacity: 1, 
        duration: 0.8, 
        stagger: 0.2, 
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '.social-proof-container',
          start: 'top 95%',
        }
      }
    );
  }
</script>
