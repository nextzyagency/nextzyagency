---
// Services.astro
import Star from '../ui/Star.astro';

const plans = [
  {
    title: "Landing page",
    color: "blue",
    features: [
      "Diseño adaptable para móvil",
      "Certificado de seguridad SSL",
      "Conexión chat de WhatsApp",
      "Hosting y dominio por 1 año gratis",
      "Diseño optimizado para la conversión de visitas en clientes cualificados",
      "Dominios .com o .co incluidos por 1 año",
      "hasta 5 correos corporativos completamente gratis",
      "Diseño e imagenes elegidas por el cliente",
      "1 mes de mantenimiento incluido"


    ]
  },
  {
    title: "Web Corporativa",
    color: "purple",
    features: [
      "Diseño adaptable para móvil",
      "Certificado de seguridad SSL",
      "Conexión chat de WhatsApp",
      "Hosting y dominio por 1 año gratis",
      "Diseño optimizado para la conversión de visitas en clientes cualificados",
      "Dominios .com o .co incluidos por 1 año",
      "hasta 5 correos corporativos completamente gratis",
      "Diseño e imagenes elegidas por el cliente",
      "1 mes de mantenimiento incluido",
      "Hasta 5 secciones distintas",
      "Optimizado para SEO y adquisición de clientes",
      "La mejor opcion para posicionarte en google"
    ]
  },
  {
    title: "E-Commerce",
    color: "emerald",
    features: [
      "Diseño adaptable para móvil",
      "Certificado de seguridad SSL",
      "Conexión chat de WhatsApp",
      "Hosting y dominio por 1 año gratis",
      "Diseño optimizado para la conversión de visitas en clientes cualificados",
      "Dominios .com o .co incluidos por 1 año",
      "hasta 5 correos corporativos completamente gratis",
      "Diseño e imagenes elegidas por el cliente",
      "1 mes de mantenimiento incluido",
      "Diseño optimizado para la compra de productos online",
      "Integración con pasarelas de pago",
      "Sección de productos vinculado a una base de datos",
      "La mejor opción para almacenes y tiendas físicas",
      "Hasta 15 productos por seccion",
      "Pagina de pago y carrito de compras"
    ]
  }
];

const getColorClasses = (color: string) => {
  if (color === 'blue') return { bg: 'from-blue-500/20', blob: 'bg-blue-600/30', border: 'border-blue-500/30', text: 'text-blue-400' };
  if (color === 'purple') return { bg: 'from-nextzy-purple/20', blob: 'bg-nextzy-purple/30', border: 'border-nextzy-purple-light/30', text: 'text-nextzy-purple-light' };
  if (color === 'emerald') return { bg: 'from-emerald-500/20', blob: 'bg-emerald-600/30', border: 'border-emerald-500/30', text: 'text-emerald-400' };
  return { bg: 'from-gray-500/20', blob: 'bg-gray-600/30', border: 'border-gray-500/30', text: 'text-gray-400' };
};
---
<section id="servicios" class="relative w-full py-32 px-6 flex flex-col items-center overflow-hidden">
  <!-- Decoraciones -->
  <Star class="absolute top-10 left-1/4 w-10 h-10 opacity-10" />
  <Star class="absolute bottom-10 right-1/4 w-6 h-6 opacity-20 text-nextzy-purple-light" />

  <div class="relative w-full max-w-7xl mx-auto flex flex-col items-center text-center mb-16 md:mb-24 z-10">
    <div class="text-nextzy-purple-light font-mono mb-8 tracking-widest uppercase text-sm font-semibold border border-nextzy-purple/30 bg-nextzy-purple/10 px-4 py-2 rounded-full inline-block backdrop-blur-sm">
      // Nuestros Planes
    </div>
    <h2 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tighter text-nextzy-white uppercase leading-tight py-2">
      Páginas web que <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-nextzy-purple-light to-nextzy-purple-dark filter drop-shadow-[0_0_15px_rgba(138,79,255,0.3)] inline-block pt-2 pb-2">venden y escalan.</span>
    </h2>
    <p class="text-nextzy-gray-400 text-lg max-w-2xl mt-4">Diseño web profesional en tres formatos adaptados al tamaño y objetivos de tu negocio.</p>
  </div>

  <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8 relative z-10 cards-container">
    {plans.map((plan) => {
      const colors = getColorClasses(plan.color);
      return (
        <div class="pricing-card relative flex flex-col bg-[#12161f] border border-white/5 rounded-[2rem] overflow-hidden group shadow-2xl hover:border-white/10 transition-all duration-500">
          
          <!-- Efecto Cúspide de Color (Semejante al diseño wavy abstracto de referencia) -->
          <div class={`absolute top-0 inset-x-0 h-64 bg-gradient-to-b ${colors.bg} to-transparent opacity-50 pointer-events-none`}></div>
          <div class={`absolute -top-32 left-1/2 -translate-x-1/2 w-80 h-80 ${colors.blob} blur-[90px] rounded-full pointer-events-none group-hover:opacity-100 transition-opacity duration-700 opacity-50`}></div>
          
          <div class="p-8 md:p-10 relative z-10 flex flex-col h-full">
            <h3 class="text-3xl font-bold text-white mb-2 tracking-tight">{plan.title}</h3>
            
            <!-- Título secundario para equilibrar altura -->
            <p class="text-sm text-nextzy-gray-400 mb-8 border-b border-white/10 pb-8 h-12">
              Transformamos tus objetivos en una experiencia digital.
            </p>

            <a
              href="#contacto"
              title={`Solicitar ${plan.title} - Nextzy Agency`}
              class={`w-full py-4 rounded-xl flex items-center justify-center font-bold text-sm tracking-widest uppercase transition-all duration-300 border ${colors.border} bg-white/5 hover:bg-white/10 text-white mb-8 group-hover:shadow-[0_0_20px_rgba(255,255,255,0.05)]`}
            >
              Quiero este plan
            </a>

            <div class="flex flex-col gap-4 flex-grow tracking-tight">
              <span class="text-xs font-mono text-nextzy-gray-500 uppercase tracking-widest mb-2">Características incluidas</span>
              {plan.features.map(feature => (
                <div class="flex items-start gap-3">
                  <svg class={`w-5 h-5 shrink-0 ${colors.text} mt-0.5`} fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-nextzy-gray-300 text-sm md:text-[0.95rem] leading-snug">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>


