---
// Testimonials.astro — Proyectos Anteriores
const projects = [
  {
    category: "Estética & Bienestar",
    name: "Go Essence",
    subtitle: "Clínica de estética en Barranquilla",
    tags: ["SEO Local", "Landing Page", "Copy Persuasivo"],
    image: "/imagenes/testimonials/go-essence.png",
    description:
      "Pasó de depender exclusivamente del voz a voz a generar citas constantes desde Google cada semana, con una estrategia enfocada en SEO local y conversión.",
    url: "https://go-essence.pages.dev",
  },
  {
    category: "Salud & Odontología",
    name: "Oralproface",
    subtitle: "Clínica odontológica de especialidades",
    tags: ["SEO On-Page", "Diseño Web", "Optimización de Velocidad"],
    image: "/imagenes/testimonials/oralproface.png",
    description:
      "Rediseño completo orientado a conversión y SEO On-Page, logrando posicionamiento en la primera página de Google y duplicando las consultas mensuales.",
    url: "https://oralproface.pages.dev",
  },
];
---

<section
  id="proyectos"
  class="relative w-full py-24 md:py-32 overflow-hidden"
>
  <!-- Background glows -->
  <div
    class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-purple-900/20 blur-[140px] -translate-y-1/2 rounded-full pointer-events-none"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-64 h-64 bg-purple-900/15 blur-[100px] rounded-full pointer-events-none"
  ></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16 proj-header">
      <div
        class="inline-block text-[#8A4FFF] font-mono tracking-widest uppercase text-xs font-semibold border border-[#8A4FFF]/30 bg-[#8A4FFF]/10 px-4 py-2 rounded-full backdrop-blur-sm mb-6"
      >
        Resultados reales
      </div>
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-white mb-5 leading-tight"
      >
        Proyectos <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[#8A4FFF] to-[#b68ef8]"
          >Anteriores</span
        >
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed">
        Marcas reales que confiaron en nuestra metodología y transformaron su
        presencia digital en resultados medibles.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch proj-cards">
      {
        projects.map((p) => (
          <article class="group h-full flex flex-col rounded-3xl overflow-hidden border border-white/10 bg-[#0d0d10] transition-all duration-500 hover:border-[#8A4FFF]/50 hover:shadow-[0_0_60px_rgba(138,79,255,0.15)]">

            <!-- Color accent bar -->
            <div class="h-[3px] w-full bg-gradient-to-r from-[#8A4FFF] to-[#b68ef8] opacity-60 group-hover:opacity-100 transition-opacity duration-500" />

            <div class="flex flex-col gap-6 p-8 flex-1">

              <!-- Identity -->
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-[10px] font-mono text-[#8A4FFF] uppercase tracking-widest mb-2">
                    {p.category}
                  </p>
                  <h3 class="text-2xl font-black text-white tracking-tight">
                    {p.name}
                  </h3>
                  <p class="text-gray-500 text-sm mt-1">{p.subtitle}</p>
                </div>
                <span class="shrink-0 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                  Activo
                </span>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <span class="text-xs text-gray-400 bg-white/5 border border-white/10 px-3 py-1 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Project screenshot -->
              <div class="rounded-xl overflow-hidden border border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
                <img
                  src={p.image}
                  alt={`Captura de pantalla del proyecto ${p.name}`}
                  title={`Proyecto ${p.name} — Nextzy Agency`}
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="500"
                  class="w-full h-[220px] object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]"
                />
              </div>

              <!-- Description -->
              <p class="text-gray-400 text-sm leading-relaxed">{p.description}</p>

              <!-- Link -->
              <div class="mt-auto pt-2">
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={`Ver proyecto ${p.name}`}
                  class="inline-flex items-center gap-2 text-sm font-semibold text-[#8A4FFF] hover:text-[#b68ef8] transition-colors duration-300 group/link"
                >
                  Ver proyecto
                  <svg
                    class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M14 5l7 7m0 0l-7 7m7-7H3"
                    />
                  </svg>
                </a>
              </div>

            </div>
          </article>
        ))
      }
    </div>

  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo(
      ".proj-header",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: { trigger: "#proyectos", start: "top 80%" },
      }
    );

    gsap.fromTo(
      ".proj-cards > article",
      { y: 50, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.9,
        stagger: 0.2,
        ease: "power2.out",
        scrollTrigger: { trigger: ".proj-cards", start: "top 90%" },
      }
    );
  });
</script>
