---
// Header.astro
---
<header id="main-header" class="fixed top-6 left-1/2 -translate-x-1/2 w-[95%] md:w-[90%] max-w-5xl z-50 rounded-full px-5 py-3 flex items-center justify-between bg-[#1f2229]/80 backdrop-blur-xl border border-white/10 shadow-[0_20px_40px_rgba(0,0,0,0.4)] transition-all duration-300">
  
  <!-- Logo -->
  <div class="flex-1 flex justify-center sm:justify-start">
    <div class="flex flex-col items-center sm:items-end leading-none select-none">
      <div class="flex items-center">
        <span class="font-bold text-2xl tracking-tight text-[#e2e8f0]">nextzy</span>
      </div>
      <span class="text-[10px] text-gray-400 font-medium tracking-widest uppercase mt-[2px]">agency</span>
    </div>
  </div>

  <!-- Links -->
  <nav class="hidden md:flex flex-1 justify-center gap-3">
    <a href="#inicio" class="text-sm font-medium text-gray-300 hover:text-white transition-colors px-5 py-1.5 rounded-full border border-gray-600/60 hover:border-gray-400 bg-white/5">Inicio</a>
    <a href="#servicios" class="text-sm font-medium text-gray-300 hover:text-white transition-colors px-5 py-1.5 rounded-full border border-gray-600/60 hover:border-gray-400 bg-white/5">Servicios</a>
    <a href="#nosotros" class="text-sm font-medium text-gray-300 hover:text-white transition-colors px-5 py-1.5 rounded-full border border-gray-600/60 hover:border-gray-400 bg-white/5">Nosotros</a>
    <a href="#contacto" class="text-sm font-medium text-gray-300 hover:text-white transition-colors px-5 py-1.5 rounded-full border border-gray-600/60 hover:border-gray-400 bg-white/5">Contacto</a>
  </nav>

  <!-- CTA -->
  <div class="hidden sm:flex flex-1 justify-end items-center gap-4">
    <a href="#contacto" class="bg-[#8A4FFF] hover:bg-[#7b42ea] text-white text-sm font-medium py-2 px-6 rounded-full transition-colors hidden md:block shadow-[0_0_20px_rgba(138,79,255,0.3)] whitespace-nowrap">
      Reservar Cita
    </a>
  </div>
</header>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const header = document.getElementById('main-header');

  if (header) {
    ScrollTrigger.create({
      start: 'top -50px',
      end: 99999,
      onEnter: () => gsap.to(header, { backgroundColor: 'rgba(21, 25, 33, 0.95)', y: -5, duration: 0.3 }),
      onLeaveBack: () => gsap.to(header, { backgroundColor: 'rgba(31, 34, 41, 0.8)', y: 0, duration: 0.3 })
    });
  }
</script>
