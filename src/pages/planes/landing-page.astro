---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/ui/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import Star from "../../components/ui/Star.astro";

// Color de acento: AZUL (igual que la card de Services)
const accent = {
  hex: "#3B82F6",
  glow: "rgba(59,130,246,0.4)",
  glowStrong: "rgba(59,130,246,0.6)",
  bgLight: "bg-blue-600/10",
  border: "border-blue-500/30",
  text: "text-blue-400",
  gradient: "from-blue-300 via-blue-400 to-blue-600",
  badge: "border-blue-500/40 bg-blue-500/10 text-blue-300",
  iconBg: "bg-blue-600/20",
  iconBorder: "border-blue-400/30",
  sweepColor: "#3B82F6",
  sweepShadow: "rgba(59,130,246,0.4)",
};

const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061A1.125 1.125 0 0 1 3 16.811V8.69ZM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061a1.125 1.125 0 0 1-1.683-.977V8.69Z" />`,
    title: "Diseño orientado a la conversión",
    desc: "Cada elemento visual y cada llamada a la acción está diseñado para convertir al visitante en un cliente cualificado. Estructuras probadas de alta conversión.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.038 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.038-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />`,
    title: "Hosting + Dominio .com/.co por 1 año",
    desc: "Publicamos tu landing en un dominio profesional con SSL activo desde el primer día. Sin costos ocultos ni configuraciones: tu negocio en línea de inmediato.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.654-4.654m5.96-4.767 3.029-2.496a1.5 1.5 0 0 0-1.082-2.646H14.17a1.5 1.5 0 0 0-1.082 2.646l3.029 2.496" />`,
    title: "1 mes de mantenimiento y soporte",
    desc: "Te acompañamos 30 días post-lanzamiento con soporte técnico, ajustes de contenido y correcciones. Tu tranquilidad es parte del plan.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 4.5h3" />`,
    title: "Responsive: perfecta en cualquier pantalla",
    desc: "Tu landing luce impecable en móvil, tablet y escritorio. Más del 70% del tráfico web llega desde teléfonos: no puedes perder esa audiencia.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />`,
    title: "Chat de WhatsApp integrado",
    desc: "Conectamos cada visitante directo a tu WhatsApp. Menos fricción, más consultas, más ventas cerradas desde el primer contacto.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />`,
    title: "Certificado SSL incluido",
    desc: "Seguridad activa desde el primer día. El candado verde genera confianza inmediata y es un factor de posicionamiento en Google.",
  },
];

const forWho = [
  "Tienes un servicio concreto y quieres que Google te encuentre.",
  "Lanzas campañas en Meta o Google Ads y necesitas una página destino profesional.",
  "No quieres una web compleja, solo algo que convierta visitas en consultas reales.",
  "Eres freelancer, consultor, terapeuta, entrenador o profesional independiente.",
  "Acabas de emprender y necesitas presencia digital sin grandes inversiones.",
  "Tu competencia ya tiene web y no puedes quedarte atrás.",
];

const faqs = [
  {
    q: "¿Cuánto tiempo tarda en estar lista?",
    a: "El tiempo promedio es de 7 a 14 días hábiles desde que se aprueba el diseño y se entregan los materiales (textos, imágenes, logo).",
  },
  {
    q: "¿Puedo pedir cambios al diseño?",
    a: "Sí. Tienes hasta 2 rondas de revisión incluidas durante el desarrollo. Cambios adicionales se cotizan por separado.",
  },
  {
    q: "¿Qué pasa después del mes de mantenimiento?",
    a: "Puedes contratar nuestro plan de mantenimiento mensual o solicitar cambios puntuales cuando los necesites. Te asesoramos sin compromiso.",
  },
  {
    q: "¿La landing queda posicionada en Google?",
    a: "Implementamos las bases de SEO técnico (metaetiquetas, velocidad, estructura de encabezados, canonical). El posicionamiento orgánico depende también de la autoridad del dominio y la estrategia de contenidos.",
  },
];
---

<Layout
  title="Landing Page Profesional | Plan Nextzy Agency"
  description="Conoce en detalle el plan Landing Page de Nextzy Agency: diseño enfocado en conversión, hosting + dominio gratis por 1 año y soporte incluido."
>
  <Header />
  <main class="w-full">
    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section
      class="relative w-full min-h-[90vh] flex flex-col items-center justify-center overflow-hidden pt-32 pb-20 px-6"
    >
      <!-- Sweep line azul (mismo estilo que el Hero del index) -->
      <div
        class="opacity-40 absolute bottom-0 left-0 w-full h-[35vh] z-0 overflow-hidden pointer-events-none flex items-end justify-center"
      >
        <div
          class={`w-[150%] md:w-[120%] h-[150%] md:h-[200%] border-t-[3px] rounded-[100%] absolute top-[50%] -translate-y-[20%] opacity-70`}
          style={`border-color: ${accent.hex}; box-shadow: 0 -10px 60px ${accent.sweepShadow};`}
        >
        </div>
      </div>

      <!-- Spotlight esquina superior derecha -->
      <div
        class="absolute top-0 right-0 w-[400px] h-[400px] bg-blue-400/8 blur-[120px] rounded-full pointer-events-none z-0 translate-x-1/4 -translate-y-1/4"
      >
      </div>
      <div
        class="absolute -top-[10%] right-[15%] w-[120px] h-[120%] bg-gradient-to-b from-blue-400/8 to-transparent rotate-[35deg] blur-xl origin-top pointer-events-none z-0"
      >
      </div>

      <!-- Estrellas decorativas -->
      <Star
        class="absolute top-32 left-10 w-6 h-6 opacity-30 hidden md:block text-blue-400"
      />
      <Star
        class="absolute bottom-20 right-16 w-8 h-8 opacity-25 hidden md:block text-blue-300"
      />

      <!-- Dot pattern bottom-left -->
      <div
        class="absolute bottom-20 left-12 z-0 opacity-20 flex flex-wrap w-[80px] gap-3 pointer-events-none hidden md:flex"
      >
        {
          Array.from({ length: 20 }).map(() => (
            <div class="w-1.5 h-1.5 bg-blue-500 rounded-full" />
          ))
        }
      </div>

      <div class="relative z-10 w-full max-w-4xl mx-auto text-center">
        <!-- Breadcrumb -->
        <nav
          class="flex items-center justify-center gap-2 text-sm text-nextzy-gray-500 mb-8"
          aria-label="Breadcrumb"
        >
          <a
            href="/"
            title="Inicio - Nextzy Agency"
            class="hover:text-blue-400 transition-colors duration-200">Inicio</a
          >
          <span>/</span>
          <a
            href="/#servicios"
            title="Ver todos los planes"
            class="hover:text-blue-400 transition-colors duration-200">Planes</a
          >
          <span>/</span>
          <span class="text-blue-400">Landing Page</span>
        </nav>

        <!-- Badge mono -->
        <div
          class={`text-blue-300 font-mono mb-6 tracking-widest uppercase text-sm font-semibold border ${accent.border} ${accent.bgLight} px-4 py-2 rounded-full inline-block backdrop-blur-sm`}
        >
          // Plan Landing Page
        </div>

        <h1
          class="text-[clamp(2.5rem,6vw,5.5rem)] font-black tracking-tighter uppercase leading-[1.05] mb-6 text-nextzy-white"
        >
          Una página que<br />
          <span
            class={`text-transparent bg-clip-text bg-gradient-to-r ${accent.gradient}`}
            style={`filter: drop-shadow(0 0 20px ${accent.glow})`}
          >
            convierte las 24h
          </span>
        </h1>

        <p
          class="text-nextzy-gray-300 text-lg max-w-2xl mx-auto mb-10 leading-relaxed font-medium"
        >
          Diseñada para un solo objetivo: convertir visitantes desconocidos en
          clientes cualificados. Sin distracciones. Sin relleno. Solo
          conversión.
        </p>

        <a
          href="/#contacto"
          title="Solicitar Landing Page - Nextzy Agency"
          class="inline-flex items-center gap-3 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm tracking-widest uppercase px-8 py-4 rounded-full transition-all duration-300 hover:scale-[1.02]"
          style={`box-shadow: 0 0 30px ${accent.glow};`}
        >
          Quiero este plan
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- ══════════════════════════ QUE INCLUYE ══════════════════════════ -->
    <section
      class="relative w-full py-24 md:py-32 px-6 lg:px-12 flex flex-col items-center justify-center overflow-hidden"
    >
      <Star
        class="absolute top-10 right-10 w-10 h-10 opacity-20 text-blue-400"
      />
      <Star
        class="absolute bottom-10 left-10 w-7 h-7 opacity-15 text-nextzy-gray-500"
      />

      <div class="relative z-10 w-full max-w-7xl mx-auto">
        <div class="text-center mb-16 md:mb-20">
          <div
            class={`text-blue-300 font-mono mb-6 tracking-widest uppercase text-sm font-semibold border ${accent.border} ${accent.bgLight} px-4 py-2 rounded-full inline-block`}
          >
            // Que incluye
          </div>
          <h2
            class="text-4xl md:text-5xl lg:text-7xl font-black tracking-tighter text-nextzy-white uppercase leading-[1.1]"
          >
            Todo lo que necesita<br />
            <span
              class={`text-transparent bg-clip-text bg-gradient-to-r ${accent.gradient}`}
              >tu negocio para arrancar</span
            >
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 w-full">
          {
            features.map((f, i) => (
              <div
                class={`relative h-full ${i === 1 || i === 4 ? "md:translate-y-8" : ""}`}
              >
                <div class="bg-[#12161f] border border-white/5 rounded-3xl p-8 lg:p-10 flex flex-col gap-6 hover:bg-[#151a25] transition-colors duration-500 h-full">
                  <div
                    class={`w-14 h-14 rounded-2xl ${accent.iconBg} flex items-center justify-center border ${accent.iconBorder} ${accent.text}`}
                  >
                    <svg
                      class="w-7 h-7"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      set:html={f.icon}
                    />
                  </div>
                  <div class="flex flex-col gap-3">
                    <h3 class="text-xl md:text-2xl font-bold text-nextzy-white uppercase tracking-tight">
                      {f.title}
                    </h3>
                    <p class="text-nextzy-gray-300 text-sm md:text-base leading-relaxed">
                      {f.desc}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ══════════════════════════ PARA QUIEN ES ══════════════════════════ -->
    <section
      class="relative w-full py-24 md:py-32 px-6 lg:px-12 flex flex-col items-center overflow-hidden"
    >
      <div class="relative z-10 w-full max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <div
            class={`text-blue-300 font-mono mb-6 tracking-widest uppercase text-sm font-semibold border ${accent.border} ${accent.bgLight} px-4 py-2 rounded-full inline-block`}
          >
            // Para quien es
          </div>
          <h2
            class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-nextzy-white uppercase leading-[1.1]"
          >
            Este plan es <span
              class={`text-transparent bg-clip-text bg-gradient-to-r ${accent.gradient}`}
              >ideal si...</span
            >
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            forWho.map((item) => (
              <div class="bg-[#12161f] border border-white/5 rounded-3xl p-7 flex items-start gap-4 hover:bg-[#151a25] transition-colors duration-500">
                <div
                  class={`w-8 h-8 rounded-xl ${accent.iconBg} border ${accent.iconBorder} flex items-center justify-center shrink-0 mt-0.5`}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class={`w-4 h-4 ${accent.text}`}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m4.5 12.75 6 6 9-13.5"
                    />
                  </svg>
                </div>
                <span class="text-nextzy-gray-300 text-sm md:text-base leading-relaxed">
                  {item}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════ FAQ ══════════════════════════════ -->
    <section
      class="relative w-full py-24 md:py-32 px-6 lg:px-12 flex flex-col items-center overflow-hidden"
    >
      <Star class="absolute top-10 left-10 w-8 h-8 opacity-20 text-blue-400" />
      <div class="relative z-10 w-full max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <div
            class={`text-blue-300 font-mono mb-6 tracking-widest uppercase text-sm font-semibold border ${accent.border} ${accent.bgLight} px-4 py-2 rounded-full inline-block`}
          >
            // Preguntas frecuentes
          </div>
          <h2
            class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-nextzy-white uppercase leading-[1.1]"
          >
            Resolvemos<br />
            <span
              class={`text-transparent bg-clip-text bg-gradient-to-r ${accent.gradient}`}
              >tus dudas</span
            >
          </h2>
        </div>
        <div class="flex flex-col gap-5">
          {
            faqs.map((faq) => (
              <div class="bg-[#12161f] border border-white/5 rounded-3xl p-8 hover:bg-[#151a25] transition-colors duration-500">
                <h3 class="text-nextzy-white font-bold text-lg uppercase tracking-tight mb-3">
                  {faq.q}
                </h3>
                <p class="text-nextzy-gray-300 text-sm md:text-base leading-relaxed">
                  {faq.a}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ════════════════════════════ CTA FINAL ════════════════════════════ -->
    <section
      class="relative w-full py-24 md:py-32 px-6 flex flex-col items-center justify-center overflow-hidden"
    >
      <!-- Sweep line superior -->
      <div
        class="absolute top-0 left-0 w-full h-[20vh] z-0 overflow-hidden pointer-events-none flex items-start justify-center"
      >
        <div
          class="w-[150%] h-[400%] border-b-[2px] rounded-[100%] absolute -top-[300%]"
          style={`border-color: ${accent.hex}; opacity:0.3;`}
        >
        </div>
      </div>

      <Star
        class="absolute bottom-16 right-12 w-8 h-8 opacity-25 text-blue-400 hidden md:block"
      />

      <div class="relative z-10 max-w-4xl mx-auto text-center w-full">
        <h2
          class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tighter text-nextzy-white uppercase leading-[1.05] mb-6"
        >
          ¿Listo para tu<br />
          <span
            class={`text-transparent bg-clip-text bg-gradient-to-r ${accent.gradient}`}
            style={`filter: drop-shadow(0 0 20px ${accent.glow})`}
          >
            Landing Page?
          </span>
        </h2>
        <p
          class="text-nextzy-gray-300 text-lg max-w-xl mx-auto mb-10 leading-relaxed"
        >
          Escríbenos hoy y en menos de 48 horas te enviamos una propuesta
          personalizada.
        </p>
        <a
          href="/#contacto"
          title="Solicitar Landing Page - Nextzy Agency"
          class="inline-flex items-center gap-3 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm tracking-widest uppercase px-10 py-5 rounded-full transition-all duration-300 hover:scale-[1.02]"
          style={`box-shadow: 0 0 35px ${accent.glow};`}
        >
          Quiero mi landing page
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Hero
  gsap.fromTo(
    "h1",
    { y: 50, opacity: 0 },
    { y: 0, opacity: 1, duration: 1, ease: "power3.out", delay: 0.2 },
  );
  gsap.fromTo(
    "h1 + p",
    { y: 20, opacity: 0 },
    { y: 0, opacity: 1, duration: 1, ease: "power2.out", delay: 0.8 },
  );

  // Sections
  document.querySelectorAll("section").forEach((section, i) => {
    if (i === 0) return;
    gsap.fromTo(
      section.querySelector("h2"),
      { y: 50, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section.querySelector("h2"),
          start: "top 80%",
        },
      },
    );
    section.querySelectorAll(".bg-\\[\\#12161f\\]").forEach((card: any, j) => {
      gsap.fromTo(
        card,
        { y: 40, opacity: 0, scale: 0.97 },
        {
          y: 0,
          opacity: 1,
          scale: 1,
          duration: 0.7,
          delay: j * 0.1,
          ease: "power3.out",
          scrollTrigger: { trigger: card, start: "top 85%" },
        },
      );
    });
  });
</script>
